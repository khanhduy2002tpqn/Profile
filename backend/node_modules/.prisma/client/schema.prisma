datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  OWNER
  ADMIN
}

model Organization {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  logoUrl   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  seasons   Season[]
  users     User[]
}

model User {
  id             String       @id @default(uuid())
  email          String       @unique
  passwordHash   String
  role           Role         @default(ADMIN)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  auditLogs      AuditLog[]
}

model Season {
  id             String       @id @default(uuid())
  seasonCode     String // e.g., SC2026, SC2027
  name           String // e.g., Summer Camp 2026
  year           Int
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  isActive       Boolean      @default(false)
  students       Student[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([organizationId, seasonCode])
}

model Student {
  id           String        @id @default(uuid())
  campId       String // e.g., SC2026-CAMP001
  publicId     String        @unique // e.g., random 9-char token
  fullName     String
  age          Int
  hometown     String
  avatarUrl    String?
  qrCodeUrl    String?
  seasonId     String
  season       Season        @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  activities   Activity[]
  certificates Certificate[]
  projects     Project[]
  awards       Award[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@unique([seasonId, campId])
}

model Activity {
  id        String   @id @default(uuid())
  studentId String
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  imageUrl  String
  order     Int      @default(0)
  createdAt DateTime @default(now())
}

model Certificate {
  id        String   @id @default(uuid())
  studentId String
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  imageUrl  String
  createdAt DateTime @default(now())
}

model Project {
  id          String   @id @default(uuid())
  studentId   String
  student     Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  title       String
  description String
  coverUrl    String?
  pptUrl      String? // PPT download link
  pdfUrl      String? // PDF download link
  videoUrl    String? // Optional YouTube/Vimeo embed
  order       Int      @default(0)
  createdAt   DateTime @default(now())
}

model Award {
  id          String   @id @default(uuid())
  studentId   String
  student     Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  title       String
  description String
  icon        String   @default("trophy") // e.g., trophy, medal, star
  imageUrl    String?
  createdAt   DateTime @default(now())
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  action    String // e.g., IMPORT_STUDENTS, DELETE_STUDENT
  details   String? // JSON string or summary
  ipAddress String?
  createdAt DateTime @default(now())
}
